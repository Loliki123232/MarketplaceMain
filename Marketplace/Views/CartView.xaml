<UserControl x:Class="Marketplace.Views.CartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Marketplace.Converters"
             ScrollViewer.CanContentScroll="True">

    <UserControl.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="🛒 Корзина" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

            <!-- Заголовки -->
            <Border Grid.Row="1" Background="#F8F9FA" Padding="12" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Товар" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Цена" FontWeight="Bold" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Column="2" Text="Количество" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="Сумма" FontWeight="Bold" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Column="4" Text=""/>
                </Grid>
            </Border>

            <!-- Список товаров -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Cart}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E9ECEF" BorderThickness="0,0,0,1" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding ProductName}" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding UnitPrice, StringFormat={}{0:N0} ₽}" 
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Content="−" Width="28" Height="28" Background="#E9ECEF" BorderThickness="0"
                                                Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <TextBlock Text="{Binding Quantity}" Width="40" TextAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
                                        <Button Content="+" Width="28" Height="28" Background="#E9ECEF" BorderThickness="0"
                                                Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="3" Text="{Binding Subtotal, StringFormat={}{0:N0} ₽}" 
                                               HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FF5722"/>

                                    <Button Grid.Column="4" Content="🗑" Background="Transparent" BorderThickness="0" 
                                            Foreground="#DC3545" Cursor="Hand" FontSize="14"
                                            Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Промокод и итоги -->
            <Border Grid.Row="3" Background="#F8F9FA" Padding="15" Margin="0,15,0,0">
                <StackPanel>
                    <!-- Поле ввода промокода -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" Text="{Binding PromoCode, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Введите промокод" Margin="0,0,10,0" Padding="10"/>

                        <Button Grid.Column="1" Content="Применить" Background="#17A2B8" Foreground="White" 
                                BorderThickness="0" Padding="15,10" Width="100" Cursor="Hand"
                                Command="{Binding ApplyPromoCodeCommand}"/>
                    </Grid>

                    <!-- Сообщение о результате применения промокода -->
                    <TextBlock Text="{Binding PromoCodeMessage}" FontSize="12" 
                               Foreground="{Binding PromoCodeSuccess, Converter={StaticResource BoolToColorConverter}}"
                               Margin="0,0,0,10" TextWrapping="Wrap"/>

                    <Separator Margin="0,5,0,5"/>

                    <!-- Итоги -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Сумма заказа:" FontSize="14" Foreground="#6C757D"/>
                            <TextBlock Text="Скидка по сумме:" FontSize="14" Foreground="#6C757D" Margin="0,8,0,0"/>
                            <TextBlock Text="Скидка по промокоду:" FontSize="14" Foreground="#6C757D" Margin="0,8,0,0"/>
                            <TextBlock Text="К оплате:" FontSize="18" FontWeight="Bold" Foreground="#FF5722" Margin="0,15,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N0} ₽}" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding DiscountAmount, StringFormat={}{0:N0} ₽}" FontSize="14" Foreground="#28A745" Margin="0,8,0,0"/>
                            <TextBlock Text="{Binding PromoDiscountAmount, StringFormat={}{0:N0} ₽}" FontSize="14" Foreground="#28A745" Margin="0,8,0,0"/>
                            <TextBlock Text="{Binding FinalAmount, StringFormat={}{0:N0} ₽}" FontSize="18" FontWeight="Bold" Foreground="#FF5722" Margin="0,15,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Кнопка оформления заказа -->
            <Button Grid.Row="4" Content="Оформить заказ" Background="#FF5722" Foreground="White" BorderThickness="0" 
                    Width="180" Height="40" FontSize="14" Margin="0,15,0,0" HorizontalAlignment="Right"
                    Command="{Binding PlaceOrderCommand}"/>
        </Grid>
    </ScrollViewer>
</UserControl>