<UserControl x:Class="Marketplace.Views.CartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ScrollViewer.CanContentScroll="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="🛒 Корзина" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

            <!-- Заголовки -->
            <Border Grid.Row="1" Background="#F5F5F5" Padding="10" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Товар" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Цена" FontWeight="Bold" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Column="2" Text="Количество" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="Сумма" FontWeight="Bold" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Column="4" Text=""/>
                </Grid>
            </Border>

            <!-- Список товаров в корзине -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Cart}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding ProductName}" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding UnitPrice, StringFormat={}{0:N0} ₽}" 
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Content="-" Width="25" Height="25" Background="#E0E0E0" BorderThickness="0"
                                                Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <TextBlock Text="{Binding Quantity}" Width="35" TextAlignment="Center" FontSize="13"/>
                                        <Button Content="+" Width="25" Height="25" Background="#E0E0E0" BorderThickness="0"
                                                Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="3" Text="{Binding Subtotal, StringFormat={}{0:N0} ₽}" 
                                               HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FF5722"/>

                                    <Button Grid.Column="4" Content="✖" Background="Transparent" BorderThickness="0" 
                                            Foreground="Red" FontSize="14"
                                            Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Итоги - ИСПРАВЛЕНО: все элементы внутри одного Grid -->
            <Border Grid.Row="3" Background="White" Padding="15" Margin="0,15,0,0" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Итого:" FontSize="14" Foreground="Gray"/>
                            <TextBlock Text="Скидка:" FontSize="14" Foreground="Gray" Margin="0,8,0,0"/>
                            <TextBlock Text="К оплате:" FontSize="18" FontWeight="Bold" Foreground="#FF5722" Margin="0,10,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N0} ₽}" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding DiscountAmount, StringFormat={}{0:N0} ₽}" FontSize="14" Margin="0,8,0,0"/>
                            <TextBlock Text="{Binding FinalAmount, StringFormat={}{0:N0} ₽}" FontSize="18" FontWeight="Bold" Foreground="#FF5722" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Button Grid.Row="1" Content="Оформить заказ" Background="#FF5722" Foreground="White" BorderThickness="0" 
                            Width="150" Height="35" Margin="0,20,0,0" HorizontalAlignment="Right"
                            Command="{Binding PlaceOrderCommand}"/>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>