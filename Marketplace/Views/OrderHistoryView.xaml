<UserControl x:Class="Marketplace.Views.OrderHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ScrollViewer.CanContentScroll="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="📋 История заказов" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Orders}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="12" Margin="0,0,0,15" 
                                    Background="White" Padding="15">

                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="2" Opacity="0.08" BlurRadius="8"/>
                                </Border.Effect>

                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="Заказ №" FontSize="16" Foreground="#6C757D"/>
                                            <TextBlock Text="{Binding Id}" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="5,0,0,0"/>
                                        </StackPanel>

                                        <Border Grid.Column="2" Background="#4CAF50" CornerRadius="15" Padding="12,5">
                                            <TextBlock Text="{Binding Status}" Foreground="White" FontSize="12" 
                                                       FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        </Border>
                                    </Grid>

                                    <TextBlock Text="{Binding OrderDate, StringFormat=dd.MM.yyyy HH:mm}" 
                                               FontSize="12" Foreground="#6C757D" Margin="0,0,0,12"/>

                                    <Border Background="#F8F9FA" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#E9ECEF" BorderThickness="0,0,0,1" Padding="8,5">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Grid.Column="0" FontSize="13">
                                                                <Run Text="{Binding ProductName}" FontWeight="SemiBold"/>
                                                                <Run Text=" — "/>
                                                                <Run Text="{Binding Quantity}"/>
                                                                <Run Text=" шт × "/>
                                                                <Run Text="{Binding UnitPrice, StringFormat={}{0:N0}}"/>
                                                                <Run Text=" ₽"/>
                                                            </TextBlock>

                                                            <TextBlock Grid.Column="1" Text="{Binding Subtotal, StringFormat={}{0:N0} ₽}" 
                                                                       FontSize="13" FontWeight="Bold" Foreground="#FF5722"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                <TextBlock Text="Итого:" FontSize="13" Foreground="#6C757D" Width="60" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N0} ₽}" FontSize="13" FontWeight="SemiBold" Margin="15,0,0,0"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                <TextBlock Text="Скидка:" FontSize="13" Foreground="#6C757D" Width="60" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding DiscountAmount, StringFormat={}{0:N0} ₽}" FontSize="13" Foreground="#28A745" Margin="15,0,0,0"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <TextBlock Text="К оплате:" FontSize="16" FontWeight="Bold" Foreground="#FF5722" Width="60" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding FinalAmount, StringFormat={}{0:N0} ₽}" FontSize="16" FontWeight="Bold" Foreground="#FF5722" Margin="15,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock Grid.Row="1" Text="У вас пока нет заказов" FontSize="16" Foreground="#6C757D" 
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding Orders.Count, Converter={StaticResource BoolToVisibleConverter}}"/>
        </Grid>
    </ScrollViewer>
</UserControl>