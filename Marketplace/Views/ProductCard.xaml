<UserControl x:Class="Marketplace.Views.ProductCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Marketplace.Converters">

    <UserControl.Resources>
        <converters:ImageUrlConverter x:Key="ImageUrlConverter"/>
    </UserControl.Resources>

    <Border BorderBrush="#E0E0E0" BorderThickness="1" Margin="5" Background="White" Height="130">
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <!-- Картинка товара с именем ProductImage -->
            <Border Grid.Column="0" Width="80" Height="80" Background="#F5F5F5" Margin="0,0,10,0" VerticalAlignment="Center">
                <Image x:Name="ProductImage" Width="70" Height="70" Stretch="Uniform"
                       Source="{Binding ImageUrl, Converter={StaticResource ImageUrlConverter}}"/>
            </Border>

            <!-- Информация о товаре -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#6C757D" TextWrapping="Wrap" 
                           MaxHeight="32" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding CategoryName}" FontSize="10" Foreground="#ADB5BD"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="★" Foreground="Gold" FontSize="12"/>
                    <TextBlock Text="{Binding Rating, StringFormat={}{0:F1}}" FontSize="11" Margin="2,0,0,0" Foreground="Gray"/>
                </StackPanel>
            </StackPanel>

            <!-- Цена и кнопка -->
            <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="{Binding Price, StringFormat={}{0:N0} ₽}" 
                           FontSize="18" FontWeight="Bold" Foreground="#FF5722" Margin="0,0,0,10"/>
                <Button Content="В корзину" Background="#FF5722" Foreground="White" BorderThickness="0" 
                        Padding="12,6" FontSize="12" Cursor="Hand"
                        Click="Button_Click" Tag="{Binding}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>