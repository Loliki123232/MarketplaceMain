<UserControl x:Class="Marketplace.Views.ReturnHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="🔄 История возвратов" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding ReturnRequests}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Margin="0,0,0,15" 
                                Background="White" Padding="15">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Заголовок -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Заявка №" FontSize="13" Foreground="#6C757D"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Id}" FontSize="14" FontWeight="Bold" Margin="5,0,0,0"/>

                                <!-- Статус -->
                                <Border Grid.Row="0" Grid.Column="2" 
                                        Background="{Binding Status, Converter={StaticResource ReturnStatusToColorConverter}}" 
                                        CornerRadius="15" Padding="10,4">
                                    <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11"/>
                                </Border>

                                <!-- Дата -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" 
                                           Text="{Binding RequestDate, StringFormat=от dd.MM.yyyy HH:mm}" 
                                           FontSize="11" Foreground="#6C757D" Margin="0,8,0,8"/>

                                <!-- Товар -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" FontSize="13">
                                    <Run Text="{Binding ProductName}" FontWeight="SemiBold"/>
                                    <Run Text=" — "/>
                                    <Run Text="{Binding Quantity}"/>
                                    <Run Text=" шт"/>
                                </TextBlock>

                                <!-- Сумма -->
                                <TextBlock Grid.Row="3" Grid.Column="2" 
                                           Text="{Binding ReturnAmount, StringFormat={}{0:N2} ₽}" 
                                           FontSize="14" FontWeight="Bold" Foreground="#FF5722" Margin="0,8,0,0"/>

                                <!-- Причина (по клику) -->
                                <Button Grid.Row="3" Grid.Column="0" Content="Причина" 
                                        Background="Transparent" BorderThickness="0" 
                                        Foreground="#FF5722" Cursor="Hand" HorizontalAlignment="Left"
                                        Click="ViewReason_Click" Tag="{Binding}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Grid.Row="1" Text="У вас пока нет заявок на возврат" FontSize="16" Foreground="#6C757D" 
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding ReturnRequests.Count, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </Grid>
    </ScrollViewer>
</UserControl>