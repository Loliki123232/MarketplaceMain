<UserControl x:Class="Marketplace.Views.SelectProductForReturnView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="White" Padding="25" Margin="20" BorderBrush="#E0E0E0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Выберите товар для возврата" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="400">
                <ItemsControl ItemsSource="{Binding Order.Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding ProductName}" FontSize="14" FontWeight="Bold"/>

   
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <TextBlock Text="{Binding Quantity}" FontSize="12" Foreground="#6C757D"/>
                                            <TextBlock Text=" шт × " FontSize="12" Foreground="#6C757D"/>
                                            <TextBlock Text="{Binding UnitPrice, StringFormat={}{0:N0}}" FontSize="12" Foreground="#6C757D"/>
                                            <TextBlock Text=" ₽" FontSize="12" Foreground="#6C757D"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Button Grid.Column="1" Content="Выбрать" Background="#17A2B8" Foreground="White" 
                                            BorderThickness="0" Padding="15,8" Cursor="Hand"
                                            Click="SelectProduct_Click" Tag="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Button Grid.Row="2" Content="Отмена" Width="100" Height="35" Margin="0,15,0,0"
                    Background="#E9ECEF" Foreground="#495057" BorderThickness="0" 
                    HorizontalAlignment="Right" Click="Cancel_Click"/>
        </Grid>
    </Border>
</UserControl>